# ═══════════════════════════════════════════════════════════════════
# .env - متغيرات البيئة لمنصة SAIF.AI
# ═══════════════════════════════════════════════════════════════════

# ── المشروع ──────────────────────────────────
APP_NAME=SAIF.AI
APP_VERSION=1.0.0
DEBUG=True

# ── قاعدة البيانات ─────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/saif_ai

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenRouter (الذكاء الاصطناعي) ──────────
OPENROUTER_API_KEY=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
OPENROUTER_DEFAULT_MODEL=google/gemini-2.0-flash-lite-001

# ── Gemini (مباشر) ──────────────────────────
GEMINI_API_KEY=AQ.Ab8RN6IBlI-xxffoBpYm36BfCXRoZObtmhaff8p-odzdkUKKeQ
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# ── المزود النشط ────────────────────────────
ACTIVE_PROVIDER=openrouter

# ── OpenAI (لـ DALL-E و Whisper) ────────────
OPENAI_API_KEY=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

# ── الذاكرة ──────────────────────────────────
SHORT_MEMORY_SIZE=20
SUMMARY_TRIGGER=15

# ── الكاش ────────────────────────────────────
CACHE_TTL=3600

# ── الشخصية الافتراضية ──────────────────────
DEFAULT_PERSONA=أنت مساعد SAIF.AI الذكي والمحترف. خبير في جميع المجالات، تجيب بدقة وإحترافية وباللغة العربية الفصحى. تستخدم أسلوباً ودوداً ومحترماً.

# ── الأمان ───────────────────────────────────
RATE_LIMIT_PER_MINUTE=30

# ── الميزات ──────────────────────────────────
THINKING_MODE_ENABLED=True
IMAGE_GEN_ENABLED=True
VOICE_ENABLED=True
FILE_UPLOAD_ENABLED=True
CAMERA_ENABLED=True
DARK_MODE_DEFAULT=True

# ── الملفات ──────────────────────────────────
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp,pdf,doc,docx,txt,mp3,mp4

# ── السجلات (Logs) ──────────────────────────
LOG_LEVEL=INFO
LOG_FILE=saif_ai.log

# ── الخادم ───────────────────────────────────
HOST=0.0.0.0
PORT=8000